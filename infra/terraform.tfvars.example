# Copy to terraform.tfvars (gitignored) and fill in real values.
# NEVER put a secret in this file — no passwords, tokens, or client secrets.
# Secrets are generated by Terraform or set out-of-band in Secret Manager.

project_id = "REPLACE-WITH-GCP-PROJECT-ID"
region     = "us-central1"

# Shared platform Cloud SQL instance (defaults shown; override if needed).
# sql_instance_name = "platform-pg"
# db_tier           = "db-f1-micro"

# plant-log allow-list: the two household Google accounts (NOT secret).
allowed_emails = "you@example.com,partner@example.com"

# Google OAuth Web client ID (NOT secret; the client *secret* goes to Secret
# Manager out-of-band). Leave blank on the first apply if not yet created.
# google_client_id = ""

# Set after the first deploy, once the Cloud Run URL (or custom domain) is known,
# then re-apply. Must match an Authorized redirect URI on the OAuth client.
# google_redirect_uri = "https://<cloud-run-url>/api/auth/callback"

# The real image is shipped after day zero by gcloud/CI; leave the default
# placeholder for the first apply.
# plantlog_image = "us-docker.pkg.dev/cloudrun/container/hello"

# --- command center (the REAL gated service) ---------------------------------
# GATED OFF by default (task #36): the whole command_center.tf service is behind
# `count = var.enable_command_center ? 1 : 0`. Leave it false until the
# reachability epic (task #33). When you flip it on, you MUST also supply a real
# cc_google_client_id (a NEW OAuth Web client, separate from plant-log's; NOT
# secret) — the variable validation rejects a blank ID once the flag is true,
# because a non-empty ID both wires OIDC and arms the fail-closed DEV_AUTH guard.
# enable_command_center = true
# cc_google_client_id   = "REPLACE-WITH-COMMAND-CENTER-OAUTH-CLIENT-ID"

# Optional overrides (defaults shown):
# cc_allowed_emails      = "tyler@tylerdorland.com"   # Tyler only (decision #17)
# cc_google_redirect_uri = "https://higgs.tylerdorland.com/api/auth/callback"
# cc_command image is shipped by gcloud/CI after first apply; leave the default:
# command_center_image = "us-docker.pkg.dev/cloudrun/container/hello"
