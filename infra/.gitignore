# Local Terraform working state — never commit.
# NB: .terraform.lock.hcl IS committed (pins provider versions/hashes).
.terraform/
*.tfstate
*.tfstate.*
crash.log

# Real values (may contain project IDs / config) — commit only the *.example.
terraform.tfvars
backend.hcl
*.auto.tfvars
# EXCEPTION: ci.auto.tfvars is deliberately COMMITTED — it holds ONLY non-secret
# config that CI needs (project id, region, allow-list, OAuth client ID, public
# URLs, placeholder image). No secret ever goes in it. See infra/terraform-ci.md.
!ci.auto.tfvars
